import math

from sequre.stdlib.builtin import (
    CHEBYSHEV_DEGREE,
    via_chebyshev,
    chebyshev_exp as cheby_exp,
    chebyshev_sigmoid as cheby_sigmoid,
    chebyshev_log as cheby_log,
    chebyshev_mul_inv as cheby_mul_inv,
    chebyshev_sqrt as cheby_sqrt)


def cheby_sin(mpc, x, interval):
    return via_chebyshev(mpc, x, math.sin, interval, CHEBYSHEV_DEGREE)


def cheby_cos(mpc, x, interval):
    return via_chebyshev(mpc, x, math.cos, interval, CHEBYSHEV_DEGREE)
