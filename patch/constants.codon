from sequre.constants import *

METHOD_CHEBYSHEV: Static[str] = "chebyshev"
METHOD_TAYLOR: Static[str] = "taylor"
METHOD_FOURIER: Static[str] = "fourier"
METHOD_DECOR: Static[str] = "decor"

POLY_EVAL_CLENSHAW: Static[str] = "clenshaw"
POLY_EVAL_DECOR: Static[str] = "decor"
POLY_EVAL_NAIVE: Static[str] = "naive"

MASK: Static[int] = (1 << MPC_NBIT_F) - 1
FOURIER_DEGREE: Static[int] = 10
TAYLOR_DEGREE: Static[int] = 3
TAYLOR_STEP: float = 1e-5
EPSILON: float = 1e-7
