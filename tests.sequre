@python
def pickle_dump(path: str, data: Dict[str, List[float]]):
    """
    Temp method until Codon Jupyter is fixed.
    """
    if not data:
        return

    import pickle
    with open(path, "wb") as f:
        pickle.dump(data, f)


class StatsLog[TP]:
    mpc: MPCEnv[TP]
    data_dump: Dict[str, List[float]]
    start: float
    name: str

    def __init__(self, mpc: MPCEnv[TP], name: str, data_dump: Dict[str, List[float]]):
        self.mpc = mpc
        self.data_dump = data_dump
        self.name = name

    def __enter__(self):
        self.mpc.stats.reset_stats()
        self.start = time.time()

    def __exit__(self):
        end = time.time()

        if f'{self.name}_time' not in self.data_dump:
            self.data_dump[f'{self.name}_time'] = []
        if f'{self.name}_bytes_sent' not in self.data_dump:
            self.data_dump[f'{self.name}_bytes_sent'] = []
        if f'{self.name}_send_requests' not in self.data_dump:
            self.data_dump[f'{self.name}_send_requests'] = []
        if f'{self.name}_partitions_count' not in self.data_dump:
            self.data_dump[f'{self.name}_partitions_count'] = []
        if f'{self.name}_truncations_count' not in self.data_dump:
            self.data_dump[f'{self.name}_truncations_count'] = []
        if f'{self.name}_rounds' not in self.data_dump:
            self.data_dump[f'{self.name}_rounds'] = []

        self.data_dump[f'{self.name}_time'].append(end - self.start)
        self.data_dump[f'{self.name}_bytes_sent'].append(float(self.mpc.stats.bytes_sent))
        self.data_dump[f'{self.name}_send_requests'].append(float(self.mpc.stats.send_requests))
        self.data_dump[f'{self.name}_partitions_count'].append(float(self.mpc.stats.partitions_count))
        self.data_dump[f'{self.name}_truncations_count'].append(float(self.mpc.stats.truncations_count))
        self.data_dump[f'{self.name}_rounds'].append(float(self.mpc.stats.rounds))


def stats_log(mpc, name, data_dump):
    return StatsLog(mpc, name, data_dump)


def aggregate_stats(data_dump, name):
    for k, v in data_dump.items():
        if f"{name}_" in k:
            data_dump[k] = [v.mean(), array(v).std()]


def _test_op(
        mpc, data_dump, msg, op, raw_input, mpc_input,
        expected_result, interval, iter_count, error=0.01,
        skip_assert=False, periodic=True):
    period = interval[1] - interval[0]

    revealed_results = []
    for _ in range(iter_count):
        with stats_log(mpc, msg, data_dump):
            mpc_input.get_partitions(mpc, force=True)
            op_result = op(mpc, mpc_input, interval)
        
        if isinstance(op_result, tuple):
            mpc_result, aux_compute_time = op_result
            data_dump[f"{msg}_time"][-1] -= aux_compute_time
        else:
            mpc_result = op_result

        revealed_results.append(mpc_result.reveal(mpc).tolist())

    aggregate_stats(data_dump, msg)
    revealed_result = revealed_results.mean()
    revealed_input = mpc_input.reveal(mpc).tolist()

    if not skip_assert:
        assert_distributed_eq_approx(
            mpc, f'CP{mpc.pid}:\tSequre {msg} at interval {interval} (MPC)',
            revealed_result, expected_result, error)
        assert_distributed_eq_approx(
            mpc, f'CP{mpc.pid}:\tMPC input intact post {msg}',
            (revealed_input * period) if periodic else revealed_input,
            raw_input, error, silent_pass=True)

    data_dump[f"{msg}_result"] = revealed_result
    data_dump[f"{msg}_expected"] = expected_result


def _test_decor_trig_method(
        mpc, data_dump, floats, shared_floats,
        skip_assert, iter_count, method: Static[str]):
    foo = get_decor_trig_foo(method=method)[0]

    revealed_results = []
    for _ in range(iter_count):
        with stats_log(mpc, f"decor_{method}", data_dump):
            shared_floats.get_partitions(mpc, force=True)
            shared_result = via_decor_trig(mpc, shared_floats, method=method)
        revealed_results.append(shared_result.reveal(mpc).tolist())

    aggregate_stats(data_dump, f"decor_{method}")
    revealed_result = revealed_results.mean()
    ground_truth = foo(floats)

    if mpc.pid != 0 and not skip_assert:
        assert_eq_approx(
            f'Decor {method} for {floats}',
            revealed_result, ground_truth, error=0.02, silent_pass=True)

    data_dump[f'decor_{method}_result'] = revealed_result
    data_dump[f'decor_{method}_expected'] = ground_truth


def _test_decor_method(
        mpc, data_dump, floats, shared_floats,
        interval, skip_assert, iter_count, 
        *args, method: Static[str]):
    foo = get_decor_foos(*args, method=method)[0][0]
    if method == "polynomial":
        eval_foo = lambda x: ([args[1]].astype(float) @ foo(x))[0]
    else:
        eval_foo = foo

    revealed_results = []
    for _ in range(iter_count):
        with stats_log(mpc, f"decor_{method}", data_dump):
            shared_floats.get_partitions(mpc, force=True)
            shared_result = via_decor(
                mpc, shared_floats, interval, *args, method=method)
        revealed_results.append(shared_result.reveal(mpc).tolist())

    aggregate_stats(data_dump, f"decor_{method}")
    revealed_result = revealed_results.mean()
    ground_truth = eval_foo(floats)
    
    if mpc.pid != 0 and not skip_assert:
        assert_eq_approx(
            f'Decor {method} for {floats}',
            revealed_result, ground_truth, error=0.1, silent_pass=True)

    data_dump[f'decor_{method}_result'] = revealed_result
    data_dump[f'decor_{method}_expected'] = ground_truth


def _test_chebyshev_method(
        mpc, data_dump, floats, stensor, interval,
        iter_count, method: Static[str], degree: Static[int]):
    name = f"chebyshev_{degree}"
    _test_op(mpc, data_dump, f"{name}_sigmoid_{method}",
        partial(via_chebyshev, op=sigmoid, validate=False, method=method, degree=degree), floats, stensor,
        sigmoid(floats), interval, iter_count, skip_assert=True, periodic=False)
    
    _test_op(mpc, data_dump, f"{name}_exp_{method}",
        partial(via_chebyshev, op=exp, validate=False, method=method, degree=degree), floats, stensor,
        exp(floats), interval, iter_count, skip_assert=True, periodic=False)

    _test_op(mpc, data_dump, f"{name}_sin_{method}",
        partial(via_chebyshev, op=sin, validate=False, method=method, degree=degree), floats, stensor,
        sin(floats), interval, iter_count, skip_assert=True, periodic=False)

    _test_op(mpc, data_dump, f"{name}_cos_{method}",
        partial(via_chebyshev, op=cos, validate=False, method=method, degree=degree), floats, stensor,
        cos(floats), interval, iter_count, skip_assert=True, periodic=False)
    
    _test_op(mpc, data_dump, f"{name}_square_wave_{method}",
        partial(via_chebyshev, op=square_wave, validate=False, method=method, degree=degree), floats, stensor,
        square_wave(floats), interval, iter_count, skip_assert=True, periodic=False)

    _test_op(mpc, data_dump, f"{name}_sawtooth_wave_{method}",
        partial(via_chebyshev, op=sawtooth_wave, validate=False, method=method, degree=degree), floats, stensor,
        sawtooth_wave(floats), interval, iter_count, skip_assert=True, periodic=False)

    _test_op(mpc, data_dump, f"{name}_tanh_{method}",
        partial(via_chebyshev, op=tanh, validate=False, method=method, degree=degree), floats, stensor,
        tanh(floats), interval, iter_count, skip_assert=True, periodic=False)
    
    period = interval[1] - interval[0]
    if period <= math.pi:
        _test_op(mpc, data_dump, f"{name}_sinh_{method}",
            partial(via_chebyshev, op=sinh, validate=False, method=method, degree=degree), floats, stensor,
            sinh(floats), interval, iter_count, skip_assert=True, periodic=False)

        _test_op(mpc, data_dump, f"{name}_cosh_{method}",
            partial(via_chebyshev, op=cosh, validate=False, method=method, degree=degree), floats, stensor,
            cosh(floats), interval, iter_count, skip_assert=True, periodic=False)
        
        if interval[0] < 0:
            _test_op(mpc, data_dump, f"{name}_tan_{method}",
                partial(via_chebyshev, op=tan, validate=False, method=method, degree=degree), floats, stensor,
                tan(floats), interval, iter_count, skip_assert=True, periodic=False)
        else:
            _test_op(mpc, data_dump, f"{name}_cot_{method}",
                partial(via_chebyshev, op=cot, validate=False, method=method, degree=degree), floats, stensor,
                cot(floats), interval, iter_count, skip_assert=True, periodic=False)


def _test_taylor_method(
        mpc, data_dump, floats, stensor, interval,
        iter_count, method: Static[str], degree: Static[int]):
    name = f"taylor_{degree}"
    _test_op(mpc, data_dump, f"{name}_sin_{method}",
        partial(via_taylor, op=sin, method=method, degree=degree), floats, stensor,
        sin(floats), interval, iter_count, skip_assert=True, periodic=False)

    _test_op(mpc, data_dump, f"{name}_cos_{method}",
        partial(via_taylor, op=cos, method=method, degree=degree), floats, stensor,
        cos(floats), interval, iter_count, skip_assert=True, periodic=False)

    _test_op(mpc, data_dump, f"{name}_sigmoid_{method}",
        partial(via_taylor, op=sigmoid, method=method, degree=degree), floats, stensor,
        sigmoid(floats), interval, iter_count, skip_assert=True, periodic=False)

    _test_op(mpc, data_dump, f"{name}_exp_{method}",
        partial(via_taylor, op=exp, method=method, degree=degree), floats, stensor,
        exp(floats), interval, iter_count, skip_assert=True, periodic=False)

    _test_op(mpc, data_dump, f"{name}_tanh_{method}",
        partial(via_taylor, op=tanh, method=method, degree=degree), floats, stensor,
        tanh(floats), interval, iter_count, skip_assert=True, periodic=False)

def _test_log_reg_method(
        mpc, mpc_X, mpc_y, raw_X, raw_y, raw_initial_w, mpc_initial_w, step_size,
        epochs, data_dump, variant: Static[str], method: Static[str]):
    name = f"log_reg_{variant}_{method}"
    raw_log_reg = LogReg(raw_initial_w, variant=variant).fit(
        mpc, X=raw_X, y=raw_y, step=step_size, epochs=epochs, verbose=False, method=method)

    with stats_log(mpc, name, data_dump):
        mpc_log_reg = LogReg(mpc_initial_w, variant=variant).fit(
            mpc, X=mpc_X, y=mpc_y, step=step_size,
            epochs=epochs, verbose=False, method=method)

    if mpc.pid > 0:
        assert_eq_approx(
            f"CP{mpc.pid}:\tSequre logistic regression for {variant}-{method}",
            mpc_log_reg.coef_.reveal(mpc), raw_log_reg.coef_, error=1.0)
    if variant == "binary":
        pred = (mpc_log_reg.predict(mpc, mpc_X, method=method).reveal(mpc) > 0.5).astype(int)
        ground_truth = mpc_y.reveal(mpc).astype(int)
    elif variant == "multinomial":
        pred = mpc_log_reg.predict(mpc, mpc_X, method=method).reveal(mpc).argmax(axis=1).astype(int)
        ground_truth = mpc_y.reveal(mpc).astype(int).argmax(axis=1)
    
    accuracy = (pred == ground_truth).astype(float).mean()
    data_dump[f"{name}_accuracy"] = [accuracy]


def _eval_dti_model(
        mpc, data_dump, X, y, X_test, y_test, act_1, act_2, loss,
        epochs, batch_size, learning_rate, momentum,
        verbose, method: Static[str], degree: Static[int]):
    mpc.randomness.reset_seed(-1, hash('global'))

    name = f"dti_{act_2}_{method}_{degree}" if degree > 0 else f"dti_{act_2}_{method}"
    input_dim = X.shape[1]
    
    if act_2 == "tanh" or loss == "hinge":
        y_final = secure_operator.sub(mpc, secure_operator.mul(mpc, y, 2), 1)
    else:
        y_final = y
    
    layers = (
        Input[type(X)](input_dim),
        Dense[type(X)](act_1, 100, "normal", "zeros", kernel_scale=0.001),
        Dense[type(X)](act_2, 1, "normal", "zeros"))

    with stats_log(mpc, name, data_dump):
        model = Sequential(layers).compile(mpc, loss=loss, optimizer="mbgd")
        model.fit(
            mpc, X=X, y=y_final,
            batch_size=batch_size, step=learning_rate,
            epochs=epochs, momentum=momentum, verbose=verbose,
            method=method, degree=degree)

        preds = model.predict(
            mpc, X_test, method=method, degree=degree).reveal(mpc)
        
        if act_2 == "sigmoid":
            preds = (preds >= 0.5).astype(float)
        else:
            preds = (preds >= 0).astype(float)
    
    accuracy = (preds == y_test).mean()
    loss = model.plain_loss(mpc, y_test).reveal(mpc).flatten().mean()
    data_dump[f"{name}_accuracy"] = [accuracy]
    data_dump[f"{name}_loss"] = [loss]
    print(f"CP{mpc.pid}:\t{name} - Accuracy: {accuracy}, Loss: {loss}")


def _eval_gwas_model(
        mpc, name, data_dump, gwas_model, initial_w,
        snp_cov, pheno, step, epochs, verbose,
        method: Static[str], degree: Static[int]):
    gwas_model.coef_ = initial_w.copy()
    with stats_log(mpc, name, data_dump):
        gwas_model.fit(
            mpc, snp_cov, pheno, step=step,
            epochs=epochs, verbose=verbose,
            method=method, degree=degree)
    
    pheno_hat = gwas_model.predict(mpc, snp_cov, method=method, degree=degree).reveal(mpc)
    accuracy = (pheno_hat.round() == pheno.reveal(mpc)).astype(float).mean()
    loss = gwas_model.plain_loss(mpc, snp_cov, pheno, method=method, degree=degree).mean()

    return gwas_model.coef_.reveal(mpc)[0, 0], accuracy, loss


def _eval_mnist_model(
        mpc, name, data_dump, initial_w, train_X, train_Y,
        test_X, test_Y, epochs, verbose,
        method: Static[str], degree: Static[int]):
    print(f'\nCP{mpc.pid}:\tTesting MNIST {method} for degree {degree}...')
    mpc.randomness.reset_seed(-1, hash('global'))
    
    with stats_log(mpc, name, data_dump):
        mnist_model = mnist(
            mpc, train_X, train_Y, initial_w,
            epochs=epochs, verbose=verbose, method=method, degree=degree)
    pred = mnist_model.predict(
        mpc, test_X,
        method=method, degree=degree).reveal(mpc).argmax(axis=1)
    
    accuracy = (pred == test_Y).astype(float).mean()
    data_dump[f"{name}_accuracy"] = [accuracy]


def _eval_siren_model(
        mpc, name, data_dump, model_input, ground_truth,
        epochs, verbose, resolution, reduce_interval,
        method: Static[str], degree: Static[int]):
    name = f"siren_{name}_{method}_{degree}"
    print(f'\nCP{mpc.pid}:\tTesting SIREN {name}...\n')
    mpc.randomness.reset_seed(-1, hash('global'))

    with stats_log(mpc, name, data_dump):    
        siren_model = siren(mpc, model_input, ground_truth, n_neurons=resolution,
            loss="mean_squared_error", omega=30.0, epochs=epochs,
            learning_rate=0.2, momentum=0.9, verbose=verbose,
            reduce_interval=reduce_interval, method=method, degree=degree)
    
    predicted_img = siren_model.predict(
        mpc, model_input, method=method, degree=degree).reveal(mpc)

    loss = siren_model.plain_loss(mpc, ground_truth).flatten().mean()
    data_dump[f"{name}_loss"] = [loss]
    data_dump[f"{name}_img"] = predicted_img.flatten().tolist()
    print(f"CP{mpc.pid}:\t{name} - Loss: {loss}")


def test_boolean(mpc):
    modulus = mpc.default_mpc_modulus
    alg_struct = "ring" if modulus else "field"
    print(f'\nCP{mpc.pid}:\tTesting Sequre MPC boolean operations on {alg_struct}...')

    for i in range(100):
        with mpc.randomness.seed_switch(-1):
            rand_vec_1 = random_floats((5,), scale=1)
            rand_vec_2 = random_floats((5,), scale=1)

        fp_rand_vec_1 = double_to_fp(rand_vec_1, modulus)
        fp_rand_vec_2 = double_to_fp(rand_vec_2, modulus)
        shared_bits_vec = mpc.boolean.share_from_trusted_dealer(fp_rand_vec_1)

        bit_sum = mpc.boolean.add_public(shared_bits_vec, fp_rand_vec_2)
        sum_vec = fp_rand_vec_1.add_mod(fp_rand_vec_2, modulus)

        if mpc.pid != 0:
            assert_eq(
                f"{i}: Sequre MPC bit add for {fp_rand_vec_1} + {fp_rand_vec_2}",
                mpc.boolean.reveal(bit_sum), sum_vec,
                silent_pass=True)
        
        decor_fp_rand_vec_1 = fp_rand_vec_1.trunc_to(64)
        decor_fp_rand_vec_2 = fp_rand_vec_2.trunc_to(64)
        decor_shared_bits_vec = mpc.boolean.share_from_trusted_dealer(decor_fp_rand_vec_1)
        decor_bit_sum = mpc.boolean.add_public(decor_shared_bits_vec, decor_fp_rand_vec_2, dtype=u64)
        decor_sum_vec = decor_fp_rand_vec_1 + decor_fp_rand_vec_2

        if mpc.pid != 0:
            assert_eq(
                f"{i}: Sequre MPC bit add u64 for {decor_fp_rand_vec_1} + {decor_fp_rand_vec_2}",
                mpc.boolean.reveal(decor_bit_sum), decor_sum_vec,
                silent_pass=True)
        
        small_modulus = UInt[MPC_NBIT_K](1) << MPC_NBIT_F
        shared_vec_1 = mpc.comms.share_from_trusted_dealer(fp_rand_vec_1, modulus)
        normalizer = mpc.boolean.normalizer(shared_vec_1, modulus, small_modulus, bitlen=MPC_NBIT_F)
        normalized_vec = mpc.arithmetic.multiply(shared_vec_1, normalizer, modulus)
        normalized_rev = array(mpc.comms.print_fp(normalized_vec, modulus))
        if mpc.pid != 0:
            assert_eq(
                f"{i}: Sequre MPC normalizer for {rand_vec_1} and {normalized_rev}",
                (normalized_rev > 0.25).all() and (normalized_rev < 1.0).all(),
                True, silent_pass=True)


def test_comparisons(mpc):
    alg_struct = "ring" if mpc.default_mpc_modulus else "field"
    print(f'\nCP{mpc.pid}:\tTesting Sequre MPC comparison on {alg_struct}...')

    for i in range(100):
        with mpc.randomness.seed_switch(-1):
            rand_vec_1 = array(random_floats((5,), scale=1))
            rand_vec_2 = array(random_floats((5,), scale=1))

        stensor_1 = Sharetensor.enc(mpc, rand_vec_1)
        stensor_2 = Sharetensor.enc(mpc, rand_vec_2)

        is_pos_standard = secure_operator.gt(
            mpc, secure_operator.sub(mpc, stensor_1, stensor_2), 0)
        is_pos_decor = _decor_gt(mpc, stensor_1, stensor_2)

        if mpc.pid != 0:
            assert_eq(
                f"{i}: Sequre gt for {rand_vec_1 - rand_vec_2}",
                is_pos_standard.reveal(mpc).astype(float), (rand_vec_1 > rand_vec_2).astype(float), True)
            assert_eq(
                f"{i}: Sequre Decor gt for {rand_vec_1 - rand_vec_2}",
                is_pos_decor.reveal(mpc).astype(float), (rand_vec_1 > rand_vec_2).astype(float), True)


def test_division(mpc):
    alg_struct = "ring" if mpc.default_mpc_modulus else "field"
    print(f'\nCP{mpc.pid}:\tTesting Sequre MPC division on {alg_struct}...')

    for i in range(100):
        with mpc.randomness.seed_switch(-1):
            rand_vec_1 = array(random_floats((5,), scale=1))
            rand_vec_2 = array(random_floats((5,), scale=1))

        stensor_1 = Sharetensor.enc(mpc, rand_vec_1)
        stensor_2 = Sharetensor.enc(mpc, rand_vec_2)

        div_decor_newton = _decor_div(mpc, stensor_1, stensor_2, niter=7, method="newton")
        div_decor_goldschmidt = _decor_div(mpc, stensor_1, stensor_2, niter=15, method="goldschmidt")

        if mpc.pid != 0:
            assert_eq_approx(
                f"{i}: Sequre Decor div Newton for {rand_vec_1} / {rand_vec_2}",
                div_decor_newton.reveal(mpc).astype(float), (rand_vec_1 / rand_vec_2).astype(float),
                silent_pass=True)
            assert_eq_approx(
                f"{i}: Sequre Decor div Goldschmidt for {rand_vec_1} / {rand_vec_2}",
                div_decor_goldschmidt.reveal(mpc).astype(float), (rand_vec_1 / rand_vec_2).astype(float),
                silent_pass=True)


def test_decor_trig(mpc, interval, sample_size, iter_count):
    """
    Test Decor for computing sin and cos.
    """
    modulus = mpc.default_mpc_modulus
    print(f'\nCP{mpc.pid}:\tTesting Decor trigonometry at interval {interval}...')

    floats = linspace(*interval, sample_size)
    fp_floats = trig_double_to_fp(floats, modulus)
    shared_fp = mpc.comms.share_from_trusted_dealer(fp_floats, modulus)
    shared_floats = Sharetensor(shared_fp, modulus)
    shared_floats.fp = True
    data_dump = {'x': floats}
    period = interval[1] - interval[0]

    _test_decor_trig_method(mpc, data_dump, floats, shared_floats, False, iter_count, method="sin")
    _test_decor_trig_method(mpc, data_dump, floats, shared_floats, False, iter_count, method="cos")

    if period < math.pi:
        if interval[0] < 0:
            _test_decor_trig_method(
                mpc, data_dump, floats, shared_floats, False, iter_count, method="tan")
        else:
            _test_decor_trig_method(
                mpc, data_dump, floats, shared_floats, False, iter_count, method="cot")

    return data_dump


def test_decor(mpc, interval, sample_size, iter_count):
    """
    Test Decor.
    """
    print(f'\nCP{mpc.pid}:\tTesting Decor internal methods at interval {interval}...')

    floats = linspace(*interval, sample_size)
    shared_floats = Sharetensor.enc(mpc, array(floats))
    data_dump = {'x': floats}
    period = interval[1] - interval[0]
    skip_assert = period > DECOR_POLY_PERIOD_OF_THRS

    _test_decor_method(
        mpc, data_dump, floats, shared_floats, interval, skip_assert, iter_count, method="exp")
    _test_decor_method(
        mpc, data_dump, floats, shared_floats, interval, skip_assert, iter_count, method="sigmoid")
    _test_decor_method(
        mpc, data_dump, floats, shared_floats, interval, True, iter_count, method="tanh")
    _test_decor_method(
        mpc, data_dump, floats, shared_floats, interval, False, iter_count, 3, list(range(1, 5)), method="polynomial")

    if period <= DECOR_POLY_PERIOD_OF_THRS:
        _test_decor_method(
            mpc, data_dump, floats, shared_floats, interval, True, iter_count, method="sinh")
        _test_decor_method(
            mpc, data_dump, floats, shared_floats, interval, True, iter_count, method="cosh")
    
    return data_dump


def test_decor_fourier(mpc, interval, sample_size, iter_count):
    period = interval[1] - interval[0]
    modulus = mpc.default_mpc_modulus
    print(f'\nCP{mpc.pid}:\tTesting Decor Fourier at interval {interval}...')

    floats = linspace(*interval, sample_size)
    fp_floats = period_double_to_fp(floats, period, modulus)
    shared_fp = mpc.comms.share_from_trusted_dealer(fp_floats, modulus)
    stensor = Sharetensor(shared_fp, modulus)
    stensor.fp = True
    data_dump = {'x': floats}

    for deg in staticrange(DEGREE_LOWER_LIMIT, DEGREE_UPPER_LIMIT):
        degree: Static[int] = deg * DEGREE_SIEVE

        name = f"fourier_{degree}"
        _test_op(mpc, data_dump, f"{name}_sin",
            partial(via_fourier, op=sin, degree=degree), floats, stensor,
            sin(floats), interval, iter_count, skip_assert=True)

        _test_op(mpc, data_dump, f"{name}_cos",
            partial(via_fourier, op=cos, degree=degree), floats, stensor,
            cos(floats), interval, iter_count, skip_assert=True)

        _test_op(mpc, data_dump, f"{name}_sigmoid",
            partial(via_fourier, op=sigmoid, degree=degree), floats, stensor,
            sigmoid(floats), interval, iter_count, skip_assert=True)

        _test_op(mpc, data_dump, f"{name}_exp",
            partial(via_fourier, op=exp, degree=degree), floats, stensor,
            exp(floats), interval, iter_count, skip_assert=True)
        
        _test_op(mpc, data_dump, f"{name}_square_wave",
            partial(via_fourier, op=square_wave, degree=degree), floats, stensor,
            square_wave(floats), interval, iter_count, skip_assert=True)

        _test_op(mpc, data_dump, f"{name}_sawtooth_wave",
            partial(via_fourier, op=sawtooth_wave, degree=degree), floats, stensor,
            sawtooth_wave(floats), interval, iter_count, skip_assert=True)

        _test_op(mpc, data_dump, f"{name}_tanh",
            partial(via_fourier, op=tanh, degree=degree), floats, stensor,
            tanh(floats), interval, iter_count, skip_assert=True)
        
        if period <= math.pi:
            _test_op(mpc, data_dump, f"{name}_sinh",
                partial(via_fourier, op=sinh, degree=degree), floats, stensor,
                sinh(floats), interval, iter_count, skip_assert=True)

            _test_op(mpc, data_dump, f"{name}_cosh",
                partial(via_fourier, op=cosh, degree=degree), floats, stensor,
                cosh(floats), interval, iter_count, skip_assert=True)
            if interval[0] < 0:
                _test_op(mpc, data_dump, f"{name}_tan",
                    partial(via_fourier, op=tan, degree=degree), floats, stensor,
                    tan(floats), interval, iter_count, skip_assert=True)
            else:
                _test_op(mpc, data_dump, f"{name}_cot",
                    partial(via_fourier, op=cot, degree=degree), floats, stensor,
                    cot(floats), interval, iter_count, skip_assert=True)

    return data_dump


def test_chebyshev(mpc, interval, sample_size, iter_count):
    print(f'\nCP{mpc.pid}:\tTesting Sequre Chebyshev at interval {interval}...')
    floats = linspace(*interval, sample_size)
    stensor = Sharetensor.enc(mpc, array(floats))
    data_dump = {'x': floats}
    period = interval[1] - interval[0]
    
    for deg in staticrange(DEGREE_LOWER_LIMIT, DEGREE_UPPER_LIMIT):
        degree: Static[int] = deg * DEGREE_SIEVE

        _test_chebyshev_method(
            mpc, data_dump, floats, stensor, interval,
            iter_count, method=POLY_EVAL_CLENSHAW, degree=degree)
        # Decor poly eval overflows for large periods and degrees for now
        if degree <= 20:
            if period <= DECOR_POLY_PERIOD_OF_THRS:
                _test_chebyshev_method(
                    mpc, data_dump, floats, stensor, interval,
                    iter_count, method=POLY_EVAL_DECOR, degree=degree)

    return data_dump


def test_taylor(mpc, interval, sample_size, iter_count):
    print(f'\nCP{mpc.pid}:\tTesting Sequre Taylor at interval {interval}...')

    floats = linspace(*interval, sample_size)
    stensor = Sharetensor.enc(mpc, array(floats))
    data_dump = {'x': floats}

    for degree in staticrange(3, 10):  # Factorial cannot be computed for degree>20
        if degree % 2:  # No need to test all degrees
            continue
        _test_taylor_method(
            mpc, data_dump, floats, stensor, interval,
            iter_count, method=POLY_EVAL_DECOR, degree=degree)
        _test_taylor_method(
            mpc, data_dump, floats, stensor, interval,
            iter_count, method=POLY_EVAL_NAIVE, degree=degree)

    return data_dump


def test_log_reg(mpc):
    print(f'\nCP{mpc.pid}:\tTesting Sequre logistic regression...')

    rows = 16
    cols = 16
    with mpc.randomness.seed_switch(-1):
        X = array(random_floats((rows, cols), scale=3)) - 1.5
        target_w_binary = arange(1, cols + 1, dtype=float).reshape((cols, 1)) / cols
        y_binary = ((X @ target_w_binary).sigmoid() > 0.5).astype(float)
        
        classes = 3
        categories = (X @ target_w_binary).astype(int).abs().flatten()

        y_multinomial = zeros((rows, classes))
        for i in range(rows):
            if categories[i] > classes - 1:
                categories[i] = classes - 1
            y_multinomial[i, categories[i]] = 1.0

    mpc_X = Sharetensor.enc(mpc, X)
    mpc_y_binary = Sharetensor.enc(mpc, y_binary)
    mpc_y_multinomial = Sharetensor.enc(mpc, y_multinomial)
    
    step_size = 0.001
    epochs = 20
    features_size = cols + 1
    raw_initial_w_binary = ones((features_size, 1))
    mpc_initial_w_binary = Sharetensor.enc(mpc, raw_initial_w_binary)
    raw_initial_w_multinomial = ones((features_size, classes)) / classes
    mpc_initial_w_multinomial = Sharetensor.enc(mpc, raw_initial_w_multinomial)

    data_dump: Dict[str, List[float]] = {}
    for i in staticrange(2):
        for j in staticrange(3):
            # Codon does not support static tuples yet; using static ternaries below
            _test_log_reg_method(
                mpc, mpc_X, mpc_y_binary if i == 0 else mpc_y_multinomial,
                X, y_binary if i == 0 else y_multinomial,
                raw_initial_w_binary if i == 0 else raw_initial_w_multinomial,
                mpc_initial_w_binary if i == 0 else mpc_initial_w_multinomial,
                step_size, epochs, data_dump,
                variant="binary" if i == 0 else "multinomial",
                method=METHOD_DECOR if j == 0 else METHOD_FOURIER if j == 1 else METHOD_CHEBYSHEV)
    
    return data_dump


def test_dti(
        mpc, epochs=20, batch_size=50,
        learning_rate=0.2, momentum=0.9,
        verbose=False):
    print(f'\nCP{mpc.pid}:\tTesting DTI...')

    X_plain = loadtxt("data/dti/Xtrain", shape=(150, 6903))
    y_plain = loadtxt("data/dti/ytrain", shape=(150, 1))
    X_test_plain = loadtxt("data/dti/Xtest", shape=(48, 6903))
    y_test_plain = loadtxt("data/dti/ytest", shape=(48, 1))

    X = Sharetensor.enc(mpc, X_plain)
    y = Sharetensor.enc(mpc, y_plain)
    X_test = Sharetensor.enc(mpc, X_test_plain)

    combinations = [
        ("relu", "linear", "hinge"),
        ("relu", "sigmoid", "binary_crossentropy")
    ]
    
    degree_count: Static[int] = 3
    data_dump: Dict[str, List[float]] = {}
    for comb in combinations:
        _eval_dti_model(
            mpc, data_dump, X_plain, y_plain,
            X_test_plain, y_test_plain, *comb,
            epochs=epochs, batch_size=batch_size,
            learning_rate=learning_rate, momentum=momentum,
            verbose=verbose, method=METHOD_PLAIN, degree=0)

        if comb[1] != "sigmoid":
            continue  # Run secure models only for sigmoid output

        _eval_dti_model(
            mpc, data_dump, X, y, X_test, y_test_plain, *comb,
            epochs=epochs, batch_size=batch_size,
            learning_rate=learning_rate, momentum=momentum,
            verbose=verbose, method=METHOD_DECOR, degree=0)
        
        for deg in staticrange(degree_count):
            degree: Static[int] = (deg + 1) * 10

            _eval_dti_model(
                mpc, data_dump, X, y, X_test, y_test_plain, *comb,
                epochs=epochs, batch_size=batch_size,
                learning_rate=learning_rate, momentum=momentum,
                verbose=verbose, method=METHOD_CHEBYSHEV, degree=degree)

    return data_dump


def test_mnist(mpc, medmnist=False, epochs=20, verbose=False):
    print(f'\nCP{mpc.pid}:\tTesting MNIST...')
    
    name = "medmnist" if medmnist else "mnist"
    data_dump: Dict[str, List[float]] = {}
    with mpc.detach_dealer():
        if medmnist:
            train_X, train_Y = load_medmnist_train_data("retina", 0)
            test_X, test_Y = load_medmnist_test_data("retina", 0)
        else:
            train_X, train_Y = load_train_data("./data/mnist/", 0)
            test_X, test_Y = load_test_data("./data/mnist/", 0)
    
    np_train_X = array(train_X)
    np_train_Y = array(train_Y)
    np_test_X = array(test_X)
    np_test_Y = array(test_Y)

    classes = train_Y.shape[1]
    raw_initial_W = array(random_floats((np_train_X.shape[1] + 1, classes), scale=1.0), dtype=float) * 0.01
    
    sequre_train_X = Sharetensor.enc(mpc, np_train_X)
    sequre_train_Y = Sharetensor.enc(mpc, np_train_Y)
    sequre_test_X = Sharetensor.enc(mpc, np_test_X)
    sequre_initial_W = Sharetensor.enc(mpc, raw_initial_W)
    
    ptx_name = f"{name}_plaintext"
    decor_name = f"{name}_decor"
    
    _eval_mnist_model(
        mpc, ptx_name, data_dump, raw_initial_W, np_train_X, np_train_Y,
        np_test_X, np_test_Y, epochs, verbose,
        method=METHOD_PLAIN, degree=0)
    
    _eval_mnist_model(
        mpc, decor_name, data_dump, sequre_initial_W,
        sequre_train_X, sequre_train_Y,
        sequre_test_X, np_test_Y, epochs, verbose,
        method=METHOD_DECOR, degree=0)
    
    for deg in staticrange(1):
        degree: Static[int] = (deg + 2) * 10
        chebyshev_name = f"{name}_chebyshev_{degree}"
        
        _eval_mnist_model(
            mpc, chebyshev_name, data_dump, sequre_initial_W,
            sequre_train_X, sequre_train_Y,
            sequre_test_X, np_test_Y, epochs, verbose,
            method=METHOD_CHEBYSHEV, degree=degree)

    return data_dump


def test_gwas(mpc, inds=9000, covs=10, step=0.0001, epochs=50, verbose=False, max_snps=100):
    print(f'\nCP{mpc.pid}:\tTesting GWAS...')

    data_dump: Dict[str, List[float]] = {}
    with mpc.randomness.seed_switch(-1):
        geno, pheno, cov = load_gwas_data(
            "./data/gwas/for_sfgwas/lung", inds, covs,
            "./data/gwas/for_sfgwas/lung/rsid.txt",
            "./data/gwas/for_sfgwas/lung/top1000_assoc.txt", 100)
    snps = geno.shape[1]
    degree_count: Static[int] = 4

    betas_ptx = zeros(snps)
    accuracies_ptx = zeros(snps)
    losses_ptx = zeros(snps)

    betas_decor = zeros(snps)
    accuracies_decor = zeros(snps)
    losses_decor = zeros(snps)
    
    betas_chebyshev = zeros((degree_count, snps))
    accuracies_chebyshev = zeros((degree_count, snps))
    losses_chebyshev = zeros((degree_count, snps))

    with mpc.randomness.seed_switch(-1):
        raw_initial_w = array(random_floats((2 + covs, 1), scale=2.0), dtype=float) - 1.0  # Range: [-1.0, 1.0)

    sequre_geno = Sharetensor.enc(mpc, geno)
    sequre_pheno = Sharetensor.enc(mpc, pheno)
    sequre_cov = Sharetensor.enc(mpc, cov)
    sequre_initial_w = Sharetensor.enc(mpc, raw_initial_w)

    raw_gwas = LogReg(raw_initial_w, optimizer="bgd", variant="binary", interval=(-30.0, 30.0))
    sequre_gwas = LogReg(sequre_initial_w, optimizer="bgd", variant="binary", interval=(-30.0, 30.0))

    ptx_name = f"gwas_plaintext"
    decor_name = f"gwas_decor"

    for snp_idx in range(geno.shape[1]):
        if snp_idx >= max_snps:
            break

        print(f'CP{mpc.pid}:\tTesting SNP {snp_idx}... \n')
        snp_ptx = array(geno)[:, snp_idx].reshape(-1, 1)
        snp_cov_ptx = snp_ptx.hstack(cov)
        snp_sequre = sequre_geno[:, snp_idx].expand_dims().reshape([len(snp_ptx), 1])
        snp_cov_sequre = snp_sequre.hstack(sequre_cov)
        
        betas_ptx[snp_idx], accuracies_ptx[snp_idx], losses_ptx[snp_idx] = _eval_gwas_model(
            mpc, ptx_name, data_dump, raw_gwas, raw_initial_w,
            snp_cov_ptx, pheno, step, epochs, verbose,
            method=METHOD_PLAIN, degree=0)

        betas_decor[snp_idx], accuracies_decor[snp_idx], losses_decor[snp_idx] = _eval_gwas_model(
            mpc, decor_name, data_dump, sequre_gwas, sequre_initial_w,
            snp_cov_sequre, sequre_pheno, step, epochs, verbose,
            method=METHOD_DECOR, degree=0)
        
        for deg in staticrange(degree_count):
            degree: Static[int] = (deg + 2) * 10
            chebyshev_name = f"gwas_chebyshev_{degree}"

            betas_chebyshev[deg][snp_idx], accuracies_chebyshev[deg][snp_idx], losses_chebyshev[deg][snp_idx] = _eval_gwas_model(
                mpc, chebyshev_name, data_dump, sequre_gwas, sequre_initial_w,
                snp_cov_sequre, sequre_pheno, step, epochs, verbose,
                method=METHOD_CHEBYSHEV, degree=degree)

    data_dump[f"{ptx_name}_betas"] = betas_ptx.tolist()
    data_dump[f"{ptx_name}_accuracy"] = accuracies_ptx.tolist()
    data_dump[f"{ptx_name}_loss"] = losses_ptx.tolist()

    data_dump[f"{decor_name}_betas"] = betas_decor.tolist()
    data_dump[f"{decor_name}_accuracy"] = accuracies_decor.tolist()
    data_dump[f"{decor_name}_loss"] = losses_decor.tolist()

    for deg in staticrange(degree_count):
        degree: Static[int] = (deg + 2) * 10
        chebyshev_name = f"gwas_chebyshev_{degree}"
        data_dump[f"{chebyshev_name}_betas"] = betas_chebyshev[deg].tolist()
        data_dump[f"{chebyshev_name}_accuracy"] = accuracies_chebyshev[deg].tolist()
        data_dump[f"{chebyshev_name}_loss"] = losses_chebyshev[deg].tolist()

    return data_dump


def test_siren(mpc, resolution=64, epochs=1000, verbose=True):
    print(f'\nCP{mpc.pid}:\tTesting SIREN...')

    with mpc.detach_dealer():
        data = load_data(resolution, ["chest", "oct", "organ"])

    data_dump: Dict[str, List[float]] = {}
    for k, v in data.items():
        model_input, ground_truth = v
        model_input_np = array(model_input)
        ground_truth_np = array(ground_truth)

        _eval_siren_model(
            mpc, k, data_dump, model_input_np, ground_truth_np,
            epochs, verbose, resolution, reduce_interval=False,
            method=METHOD_PLAIN, degree=0)
        
        mpc.comms.sync_parties()

        model_input_sequre = Sharetensor.enc(mpc, model_input_np)
        ground_truth_sequre = Sharetensor.enc(mpc, ground_truth_np)
        
        _eval_siren_model(
            mpc, k, data_dump, model_input_sequre, ground_truth_sequre,
            epochs, verbose, resolution, reduce_interval=False,
            method=METHOD_DECOR, degree=0)

    return data_dump


def test_siren_cheby(
        mpc, resolution=64, epochs=1000,
        verbose=True, reduce_interval=True):
    print(f'\nCP{mpc.pid}:\tTesting SIREN Chebyshev ...')

    with mpc.detach_dealer():
        data = load_data(resolution, ["chest", "oct", "organ"])

    data_dump: Dict[str, List[float]] = {}
    for k, v in data.items():
        model_input, ground_truth = v
        model_input_np = array(model_input)
        ground_truth_np = array(ground_truth)

        model_input_sequre = Sharetensor.enc(mpc, model_input_np)
        ground_truth_sequre = Sharetensor.enc(mpc, ground_truth_np)
        
        for deg in staticrange(2):
            degree: Static[int] = (deg + 1) * 10
            
            # Adjust epochs for reduced interval (temporarily)
            if reduce_interval and degree == 10:
                epochs = 400
            elif reduce_interval and degree == 20:
                epochs = 240
            
            _eval_siren_model(
                mpc, k, data_dump, model_input_sequre, ground_truth_sequre,
                epochs, verbose, resolution, reduce_interval=reduce_interval,
                method=METHOD_CHEBYSHEV, degree=degree)

    return data_dump


COMPILE_PRIMITIVES: Static[int] = False
COMPILE_ELEMENTARY: Static[int] = True
COMPILE_E2E: Static[int] = True

def test(mpc):
    if COMPILE_PRIMITIVES:
        test_boolean(mpc)
        test_comparisons(mpc)
        test_division(mpc)

    if COMPILE_ELEMENTARY:
        sample_size = 500
        iter_count = 3
        intervals = [
            (-math.pi / 4, math.pi / 4),
            (math.pi / 4, 3 * math.pi / 4),
            (-math.pi * 3, math.pi * 3),
            (-20.0, 20.0)
            ]
        
        with mpc.detach_dealer():
            for i, interval in enumerate(intervals):
                pickle_dump(f"dump/taylor_{i}_{MPC_NBIT_F}_CP{mpc.pid}.p", test_taylor(
                    mpc, interval, sample_size, iter_count))

                pickle_dump(f"dump/cheby_{i}_{MPC_NBIT_F}_CP{mpc.pid}.p", test_chebyshev(
                    mpc, interval, sample_size, iter_count))
                
                pickle_dump(f"dump/decor_trig_{i}_{MPC_NBIT_F}_CP{mpc.pid}.p", test_decor_trig(
                    mpc, interval, sample_size, iter_count))
                
                pickle_dump(f"dump/decor_{i}_{MPC_NBIT_F}_CP{mpc.pid}.p", test_decor(
                    mpc, interval, sample_size, iter_count))
                
                pickle_dump(f"dump/fourier_{i}_{MPC_NBIT_F}_CP{mpc.pid}.p", test_decor_fourier(
                    mpc, interval, sample_size, iter_count))
                

    if COMPILE_E2E:
        # Apps that are stable
        
        # Disable GWAS because data is proprietary
        # pickle_dump(f"dump/gwas_{MPC_NBIT_F}_CP{mpc.pid}.p", test_gwas(mpc))
        
        pickle_dump(f"dump/siren_{MPC_NBIT_F}_CP{mpc.pid}.p", test_siren(mpc))
        pickle_dump(f"dump/siren_cheby_{MPC_NBIT_F}_CP{mpc.pid}.p", test_siren_cheby(mpc, reduce_interval=False))
        # pickle_dump(f"dump/siren_cheby_reduced_{MPC_NBIT_F}_CP{mpc.pid}.p", test_siren_cheby(mpc, reduce_interval=True))
        
        # # Apps that need more testing
        # pickle_dump(f"dump/log_reg_{MPC_NBIT_F}_CP{mpc.pid}.p", test_log_reg(mpc))
        # pickle_dump(f"dump/dti_{MPC_NBIT_F}_CP{mpc.pid}.p", test_dti(mpc))
        # pickle_dump(f"dump/mnist_{MPC_NBIT_F}_CP{mpc.pid}.p", test_mnist(mpc))
        # pickle_dump(f"dump/medmnist_{MPC_NBIT_F}_CP{mpc.pid}.p", test_mnist(mpc, medmnist=True))


@local
def _local_run(mpc):
    test(mpc)

if "--local" in sys.argv:
    _local_run()
else:
    mpc = mpc()
    test(mpc)
    mpc.done()
