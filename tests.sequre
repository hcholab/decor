import time, math

from numpy.create import array

from sequre import local
from sequre.types.sharetensor import Sharetensor
from sequre.types.utils import fp_to_double
from sequre.utils.testing import assert_eq_approx, assert_distributed_eq_approx
from sequre.constants import MPC_NBIT_F

from beaver import *
from bitween import via_bitween, get_bitween_foo
from fourier import fourier_sin, fourier_cos, fourier_sigmoid, fourier_exp, fourier_log, fourier_mul_inv, fourier_sqrt
from taylor import taylor_sin, taylor_cos, taylor_sigmoid
from chebyshev import chebyshev_sin, chebyshev_cos, chebyshev_sigmoid, chebyshev_exp, chebyshev_log, chebyshev_mul_inv, chebyshev_sqrt
from utils import linspace, trig_double_to_fp, period_double_to_fp, interval_double_to_fp, sin, cos, expm1, exp, sigmoid, log, mul_inv, sqrt


@python
def pickle_dump(path: str, data: Dict[str, List[float]]):
    """
    Temp method until Codon Jupyter is fixed.
    """
    if not data:
        return

    import pickle
    with open(path, "wb") as f:
        pickle.dump(data, f)


def test_beaver_trig(mpc, interval, iterations=10, size=100):
    """
    Test Beaver's protocol for computing sine and cosine using MPC.
    """
    modulus = mpc.default_mpc_modulus
    total_partition_time = 0.0
    total_sin_time = 0.0
    total_cos_time = 0.0
    data_dump = {}

    for i in range(iterations):
        floats = linspace(*interval, size)
        fp_floats = trig_double_to_fp(floats, modulus)
        shared_fp = mpc.comms.share_from_trusted_dealer(fp_floats, modulus)

        s = time.time()
        beaver_trig_partitions = mpc.arithmetic.__beaver_partition(shared_fp, modulus)
        beaver_trig_elem = mpc.arithmetic._beaver_trig(*beaver_trig_partitions, modulus)
        e = time.time()
        total_partition_time += e - s
        
        s = time.time()
        shared_result = mpc.fp._beaver_sin(*beaver_trig_elem, modulus)
        e = time.time()
        total_sin_time += e - s
        
        revealed_sin_result = fp_to_double(mpc.comms.reveal(shared_result, modulus), modulus)
        if mpc.pid != 0:
            assert_eq_approx(
                f'Beaver sin (iteration {i}/{iterations}) for {floats}',
                revealed_sin_result,
                sin(floats), silent_pass=True)

        s = time.time()
        shared_result = mpc.fp._beaver_cos(*beaver_trig_elem, modulus)
        e = time.time()
        total_cos_time += e - s
        revealed_cos_result = fp_to_double(mpc.comms.reveal(shared_result, modulus), modulus)
        if mpc.pid != 0:
            assert_eq_approx(
                f'Beaver cos (iteration {i}/{iterations}) for {floats}',
                revealed_cos_result,
                cos(floats), silent_pass=True)
        
        data_dump = {
            'x': floats,
            'beaver_sin': revealed_sin_result,
            'beaver_sin_expected': sin(floats),
            'beaver_cos': revealed_cos_result,
            'beaver_cos_expected': cos(floats)}
    
    avg_partition_time = total_partition_time / iterations
    avg_sin_time = total_sin_time / iterations
    avg_cos_time = total_cos_time / iterations
    print(f'CP{mpc.pid}:\tGeneralized Trigonometry Beaver tests passed.\n\tRuntime per partitioning iteration: {avg_partition_time} seconds\n\tRuntime per sin iteration: {avg_sin_time} seconds\n\tRuntime per cos iteration: {avg_cos_time} seconds')
    data_dump['beaver_sin_time'] = [avg_sin_time + avg_partition_time]
    data_dump['beaver_cos_time'] = [avg_cos_time + avg_partition_time]
    return data_dump


def test_beaver_exp(mpc, interval, iterations=10, size=100):
    """
    Test Beaver's protocol for computing exp using MPC.
    """
    modulus = mpc.default_mpc_modulus
    sequre_total_time = 0.0
    data_dump = {}

    for i in range(iterations):
        floats = linspace(*interval, size)
        fp_floats = interval_double_to_fp(floats, interval, modulus)
        shared_fp = mpc.comms.share_from_trusted_dealer(fp_floats, modulus)

        s = time.time()
        beaver_exp_partitions = mpc.arithmetic.__beaver_partition(shared_fp, modulus)
        beaver_exp_elem = mpc.arithmetic._beaver_exp(*beaver_exp_partitions, interval, modulus)
        shared_result = mpc.fp._beaver_exp(*beaver_exp_elem, shared_fp, modulus)
        e = time.time()
        sequre_total_time += e - s
        
        revealed_result = fp_to_double(mpc.comms.reveal(shared_result, modulus), modulus)
        if mpc.pid != 0:
            assert_eq_approx(
                f'Beaver exp (iteration {i}/{iterations}) for {floats}',
                revealed_result,
                expm1(floats), error=0.03, silent_pass=True)

        data_dump = {
            'x': floats,
            'beaver_expm1': revealed_result,
            'beaver_expm1_expected': expm1(floats)}

    avg_time = sequre_total_time / iterations
    print(f'CP{mpc.pid}:\tGeneralized Exp Beaver tests passed.\n\t\n\tRuntime per iteration: {avg_time} seconds')
    data_dump['beaver_expm1_time'] = [avg_time]
    return data_dump


def test_op(mpc, data_dump, msg, op, raw_input, mpc_input, expected_result, interval, error=0.01, skip_assert=False, periodic=True):
    alg_struct = "ring" if mpc.default_mpc_modulus.popcnt() == 1 else "field"
    period = interval[1] - interval[0]
    
    s = time.time()
    mpc_result = op(mpc, mpc_input, interval)
    e = time.time()
    data_dump[f"{msg}_time"] = [e - s]
    revealed_result = mpc_result.reveal(mpc).tolist()
    
    revealed_input = mpc_input.reveal(mpc).tolist()
    if not skip_assert:
        assert_distributed_eq_approx(mpc, f'CP{mpc.pid}:\tSequre {msg} at interval {interval} (MPC) on {alg_struct}', revealed_result, expected_result, error)
        assert_distributed_eq_approx(mpc, f'CP{mpc.pid}:\tMPC input intact post {msg} on {alg_struct}', (revealed_input * period) if periodic else revealed_input, raw_input, error, silent_pass=True)

    data_dump[msg] = revealed_result
    data_dump[f"{msg}_expected"] = expected_result


def test_beaver_fourier(mpc, interval, size=100):
    period = interval[1] - interval[0]
    modulus = mpc.default_mpc_modulus
    alg_struct = "ring" if modulus.popcnt() == 1 else "field"
    print(f'CP{mpc.pid}:\tTesting Sequre Beaver Fourier at interval {interval} on {alg_struct} ... \n')
    
    floats = linspace(*interval, size)
    fp_floats = period_double_to_fp(floats, period, modulus)
    shared_fp = mpc.comms.share_from_trusted_dealer(fp_floats, modulus)
    stensor = Sharetensor(shared_fp, modulus)
    stensor.fp = True
    data_dump = {'x': floats}
    
    test_op(mpc, data_dump, "fourier_sin",
        fourier_sin, floats, stensor, sin(floats), interval, skip_assert=True)
    
    test_op(mpc, data_dump, "fourier_cos",
        fourier_cos, floats, stensor, cos(floats), interval, skip_assert=True)
    
    test_op(mpc, data_dump, "fourier_sigmoid",
        fourier_sigmoid, floats, stensor, sigmoid(floats), interval, skip_assert=True)
    
    test_op(mpc, data_dump, "fourier_exp",
        fourier_exp, floats, stensor, exp(floats), interval, skip_assert=True)
    
    if interval[0] > 0:
        test_op(mpc, data_dump, "fourier_log",
            fourier_log, floats, stensor, log(floats), interval, skip_assert=True)
        
        test_op(mpc, data_dump, "fourier_mul_inv",
            fourier_mul_inv, floats, stensor, mul_inv(floats), interval, skip_assert=True)

        test_op(mpc, data_dump, "fourier_sqrt",
            fourier_sqrt, floats, stensor, sqrt(floats), interval, skip_assert=True)

    return data_dump


def test_beaver_taylor(mpc, interval, size=100):
    period = interval[1] - interval[0]
    modulus = mpc.default_mpc_modulus
    alg_struct = "ring" if modulus.popcnt() == 1 else "field"
    print(f'CP{mpc.pid}:\tTesting Sequre Beaver Taylor at interval {interval} on {alg_struct} ... \n')
    
    floats = linspace(*interval, size)
    fp_floats = period_double_to_fp(floats, period, modulus)
    shared_fp = mpc.comms.share_from_trusted_dealer(fp_floats, modulus)
    stensor = Sharetensor(shared_fp, modulus)
    stensor.fp = True
    data_dump = {'x': floats}

    test_op(mpc, data_dump, "taylor_sin",
            taylor_sin, floats, stensor, sin(floats), interval)
    
    test_op(mpc, data_dump, "taylor_cos",
            taylor_cos, floats, stensor, cos(floats), interval)
    
    test_op(mpc, data_dump, "taylor_sigmoid",
            taylor_sigmoid, floats, stensor, sigmoid(floats), interval)
    
    return data_dump


def test_chebyshev(mpc, interval, size=100):
    modulus = mpc.default_mpc_modulus
    alg_struct = "ring" if modulus.popcnt() == 1 else "field"
    print(f'CP{mpc.pid}:\tTesting Sequre Chebyshev at interval {interval} on {alg_struct} ... \n')
    
    floats = linspace(*interval, size)
    stensor = Sharetensor.enc(mpc, array(floats), 0, modulus)
    data_dump = {'x': floats}
    
    test_op(mpc, data_dump, "chebyshev_sigmoid",
        chebyshev_sigmoid, floats, stensor, sigmoid(floats), interval, skip_assert=True, periodic=False)
    
    test_op(mpc, data_dump, "chebyshev_exp",
        chebyshev_exp, floats, stensor, exp(floats), interval, skip_assert=True, periodic=False)
    
    test_op(mpc, data_dump, "chebyshev_sin",
        chebyshev_sin, floats, stensor, sin(floats), interval, skip_assert=True, periodic=False)
    
    test_op(mpc, data_dump, "chebyshev_cos",
        chebyshev_cos, floats, stensor, cos(floats), interval, skip_assert=True, periodic=False)
    
    if interval[0] > 0:
        test_op(mpc, data_dump, "chebyshev_log",
            chebyshev_log, floats, stensor, log(floats), interval, skip_assert=True, periodic=False)
        
        test_op(mpc, data_dump, "chebyshev_mul_inv",
            chebyshev_mul_inv, floats, stensor, mul_inv(floats), interval, skip_assert=True, periodic=False)

        test_op(mpc, data_dump, "chebyshev_sqrt",
            chebyshev_sqrt, floats, stensor, sqrt(floats), interval, skip_assert=True, periodic=False)

    return data_dump


def _test_bitween_method(mpc, data_dump, floats, shared_floats, interval, method: Static[str]):
    foo = get_bitween_foo(method)[0]

    s = time.time()
    shared_result = via_bitween(mpc, shared_floats, interval, method=method)
    e = time.time()
    
    revealed_result = shared_result.reveal(mpc).tolist()
    if mpc.pid != 0:
        assert_eq_approx(
            f'Bitween Beaver {method} for {floats}',
            revealed_result, foo(floats), silent_pass=True)

    data_dump[f'bitween_beaver_{method}'] = revealed_result
    data_dump[f'bitween_beaver_{method}_expected'] = foo(floats)
    data_dump[f'bitween_beaver_{method}_time'] = [e - s]


def test_bitween_beaver(mpc, interval, size=100):
    """
    Test Bitween Beaver.
    """
    
    floats = linspace(*interval, size)
    shared_floats = Sharetensor.enc(mpc, array(floats))
    data_dump = {'x': floats}

    _test_bitween_method(mpc, data_dump, floats, shared_floats, interval, "expm1")
    _test_bitween_method(mpc, data_dump, floats, shared_floats, interval, "sigmoid")
    
    return data_dump


@local
def test(mpc):
    intervals = [
        (-math.pi, math.pi),
        (-1.0, 2.5),
        (math.pi * 0.25, math.pi * 0.75),
        (-5.0, 5.0)
        ]

    for i, interval in enumerate(intervals):
        pickle_dump(f"_dump_beaver_trig_{i}_{MPC_NBIT_F}.p", test_beaver_trig(mpc, interval))
        pickle_dump(f"_dump_beaver_exp_{i}_{MPC_NBIT_F}.p", test_beaver_exp(mpc, interval))
        pickle_dump(f"_dump_bitween_beaver_{i}_{MPC_NBIT_F}.p", test_bitween_beaver(mpc, interval))
        pickle_dump(f"_dump_fourier_{i}_{MPC_NBIT_F}.p", test_beaver_fourier(mpc, interval))
        pickle_dump(f"_dump_cheby_{i}_{MPC_NBIT_F}.p", test_chebyshev(mpc, interval))
    

test()
