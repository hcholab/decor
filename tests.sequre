@python
def pickle_dump(pid: int, path: str, data: Dict[str, List[float]]):
    """
    Temp method until Codon Jupyter is fixed.
    """
    if not data or pid != 1:
        return

    import pickle
    with open(path, "wb") as f:
        pickle.dump(data, f)


class StatsLog[TP]:
    mpc: MPCEnv[TP]
    data_dump: Dict[str, List[float]]
    start: float
    name: str

    def __init__(self, mpc: MPCEnv[TP], name: str, data_dump: Dict[str, List[float]]):
        self.mpc = mpc
        self.data_dump = data_dump
        self.name = name

    def __enter__(self):
        self.mpc.stats.reset_stats()
        self.start = time.time()

    def __exit__(self):
        end = time.time()
        self.data_dump[f'{self.name}_time'] = [end - self.start]
        self.data_dump[f'{self.name}_bytes_sent'] = [float(self.mpc.stats.bytes_sent)]
        self.data_dump[f'{self.name}_send_requests'] = [float(self.mpc.stats.send_requests)]
        self.data_dump[f'{self.name}_partitions_count'] = [float(self.mpc.stats.partitions_count)]
        self.data_dump[f'{self.name}_truncations_count'] = [float(self.mpc.stats.truncations_count)]


def stats_log(mpc, name, data_dump):
    return StatsLog(mpc, name, data_dump)


def test_decor_trig(mpc, interval, size=100):
    """
    Test Decor for computing sin and cos.
    """
    modulus = mpc.default_mpc_modulus
    alg_struct = "ring" if modulus.popcnt() == 1 else "field"
    print(f'CP{mpc.pid}:\tTesting Decor trigonometry at interval {interval} on {alg_struct} ... \n')

    floats = linspace(*interval, size)
    fp_floats = trig_double_to_fp(floats, modulus)
    shared_fp = mpc.comms.share_from_trusted_dealer(fp_floats, modulus)
    data_dump = {'x': floats}

    with stats_log(mpc, "decor_sin", data_dump):
        beaver_trig_partitions = mpc.arithmetic.__beaver_partition(shared_fp, modulus)
        beaver_trig_elem = mpc.arithmetic._beaver_trig(*beaver_trig_partitions, modulus)
        shared_result = mpc.fp._decor_sin(*beaver_trig_elem, modulus)
    
    revealed_sin_result = fp_to_double(mpc.comms.reveal(shared_result, modulus), modulus)
    if mpc.pid != 0:
        assert_eq_approx(
            f'Beaver sin',
            revealed_sin_result,
            sin(floats))

    with stats_log(mpc, "decor_cos", data_dump):
        beaver_trig_partitions = mpc.arithmetic.__beaver_partition(shared_fp, modulus)
        beaver_trig_elem = mpc.arithmetic._beaver_trig(*beaver_trig_partitions, modulus)
        shared_result = mpc.fp._decor_cos(*beaver_trig_elem, modulus)
    
    revealed_cos_result = fp_to_double(mpc.comms.reveal(shared_result, modulus), modulus)
    if mpc.pid != 0:
        assert_eq_approx(
            f'Beaver cos',
            revealed_cos_result,
            cos(floats), silent_pass=True)
        
    data_dump['decor_sin_result'] = revealed_sin_result
    data_dump['decor_sin_expected'] = sin(floats)
    data_dump['decor_cos_result'] = revealed_cos_result
    data_dump['decor_cos_expected'] = cos(floats)

    return data_dump


def test_decor_expm1(mpc, interval, size=100):
    """
    Test Beaver's protocol for computing exp using MPC.
    """
    modulus = mpc.default_mpc_modulus
    alg_struct = "ring" if modulus.popcnt() == 1 else "field"
    print(f'CP{mpc.pid}:\tTesting Sequre Beaver Fourier at interval {interval} on {alg_struct} ... \n')

    floats = linspace(*interval, size)
    fp_floats = interval_double_to_fp(floats, interval, modulus)
    shared_fp = mpc.comms.share_from_trusted_dealer(fp_floats, modulus)
    data_dump = {'x': floats}

    with stats_log(mpc, "decor_expm1", data_dump):
        beaver_exp_partitions = mpc.arithmetic.__beaver_partition(shared_fp, modulus)
        beaver_exp_elem = mpc.arithmetic._decor_exp(*beaver_exp_partitions, interval, modulus)
        shared_result = mpc.fp._decor_exp(*beaver_exp_elem, shared_fp, modulus)
    
    revealed_result = fp_to_double(mpc.comms.reveal(shared_result, modulus), modulus)
    if mpc.pid != 0:
        assert_eq_approx(
            f'Beaver exp',
            revealed_result,
            expm1(floats), error=0.03)

    data_dump['decor_expm1_result'] = revealed_result
    data_dump['decor_expm1_expected'] = expm1(floats)
    return data_dump


def _test_op(
        mpc, data_dump, msg, op, raw_input, mpc_input,
        expected_result, interval, error=0.01,
        skip_assert=False, periodic=True):
    alg_struct = "ring" if mpc.default_mpc_modulus.popcnt() == 1 else "field"
    period = interval[1] - interval[0]
    
    with stats_log(mpc, msg, data_dump):
        op_result = op(mpc, mpc_input, interval)
    
    if isinstance(op_result, tuple):
        mpc_result, aux_compute_time = op_result
        data_dump[f"{msg}_time"] -= aux_compute_time
    else:
        mpc_result = op_result

    revealed_result = mpc_result.reveal(mpc).tolist()
    revealed_input = mpc_input.reveal(mpc).tolist()
    if not skip_assert:
        assert_distributed_eq_approx(
            mpc, f'CP{mpc.pid}:\tSequre {msg} at interval {interval} (MPC) on {alg_struct}',
            revealed_result, expected_result, error)
        assert_distributed_eq_approx(
            mpc, f'CP{mpc.pid}:\tMPC input intact post {msg} on {alg_struct}',
            (revealed_input * period) if periodic else revealed_input,
            raw_input, error, silent_pass=True)

    data_dump[f"{msg}_result"] = revealed_result
    data_dump[f"{msg}_expected"] = expected_result


def test_decor_fourier(mpc, interval, size=100):
    period = interval[1] - interval[0]
    modulus = mpc.default_mpc_modulus
    alg_struct = "ring" if modulus.popcnt() == 1 else "field"
    print(f'CP{mpc.pid}:\tTesting Sequre Beaver Fourier at interval {interval} on {alg_struct} ... \n')
    
    floats = linspace(*interval, size)
    fp_floats = period_double_to_fp(floats, period, modulus)
    shared_fp = mpc.comms.share_from_trusted_dealer(fp_floats, modulus)
    stensor = Sharetensor(shared_fp, modulus)
    stensor.fp = True
    data_dump = {'x': floats}
    
    _test_op(mpc, data_dump, "fourier_sin",
        partial(via_fourier, op=sin), floats, stensor,
        sin(floats), interval, skip_assert=True)
    
    _test_op(mpc, data_dump, "fourier_cos",
        partial(via_fourier, op=cos), floats, stensor,
        cos(floats), interval, skip_assert=True)
    
    _test_op(mpc, data_dump, "fourier_sigmoid",
        partial(via_fourier, op=sigmoid), floats, stensor,
        sigmoid(floats), interval, skip_assert=True)
    
    _test_op(mpc, data_dump, "fourier_exp",
        partial(via_fourier, op=exp), floats, stensor,
        exp(floats), interval, skip_assert=True)
    
    _test_op(mpc, data_dump, "fourier_tanh",
        partial(via_fourier, op=tanh), floats, stensor,
        tanh(floats), interval, skip_assert=True)
    
    if interval[0] > 0:
        _test_op(mpc, data_dump, "fourier_log",
            partial(via_fourier, op=log), floats, stensor,
            log(floats), interval, skip_assert=True)
        
        _test_op(mpc, data_dump, "fourier_mul_inv",
            partial(via_fourier, op=mul_inv), floats, stensor,
            mul_inv(floats), interval, skip_assert=True)

        _test_op(mpc, data_dump, "fourier_sqrt",
            partial(via_fourier, op=sqrt), floats, stensor,
            sqrt(floats), interval, skip_assert=True)

    return data_dump


def _test_taylor_method(mpc, data_dump, floats, stensor, interval, method: Static[str]):
    _test_op(mpc, data_dump, f"taylor_sin_{method}",
        partial(via_taylor, op=sin, method=method), floats, stensor,
        sin(floats), interval, skip_assert=True, periodic=False)
    
    _test_op(mpc, data_dump, f"taylor_cos_{method}",
        partial(via_taylor, op=cos, method=method), floats, stensor,
        cos(floats), interval, skip_assert=True, periodic=False)
    
    _test_op(mpc, data_dump, f"taylor_sigmoid_{method}",
        partial(via_taylor, op=sigmoid, method=method), floats, stensor,
        sigmoid(floats), interval, skip_assert=True, periodic=False)
    
    _test_op(mpc, data_dump, f"taylor_exp_{method}",
        partial(via_taylor, op=exp, method=method), floats, stensor,
        exp(floats), interval, skip_assert=True, periodic=False)
    
    _test_op(mpc, data_dump, f"taylor_tanh_{method}",
        partial(via_taylor, op=tanh, method=method), floats, stensor,
        tanh(floats), interval, skip_assert=True, periodic=False)
    
    if interval[0] > 0:
        _test_op(mpc, data_dump, f"taylor_log_{method}",
            partial(via_taylor, op=log, method=method), floats, stensor,
            log(floats), interval, skip_assert=True, periodic=False)
        
        _test_op(mpc, data_dump, f"taylor_mul_inv_{method}",
            partial(via_taylor, op=mul_inv, method=method), floats, stensor,
            mul_inv(floats), interval, skip_assert=True, periodic=False)

        _test_op(mpc, data_dump, f"taylor_sqrt_{method}",
            partial(via_taylor, op=sqrt, method=method), floats, stensor,
            sqrt(floats), interval, skip_assert=True, periodic=False)


def test_taylor(mpc, interval, size=100):
    modulus = mpc.default_mpc_modulus
    alg_struct = "ring" if modulus.popcnt() == 1 else "field"
    print(f'CP{mpc.pid}:\tTesting Sequre Taylor at interval {interval} on {alg_struct} ... \n')
    
    floats = linspace(*interval, size)
    stensor = Sharetensor.enc(mpc, array(floats), 0, modulus)
    data_dump = {'x': floats}
    
    _test_taylor_method(mpc, data_dump, floats, stensor, interval, method=POLY_EVAL_DECOR)
    _test_taylor_method(mpc, data_dump, floats, stensor, interval, method=POLY_EVAL_NAIVE)

    return data_dump


def _test_chebyshev_method(mpc, data_dump, floats, stensor, interval, method: Static[str]):
    _test_op(mpc, data_dump, f"chebyshev_sigmoid_{method}",
        partial(via_chebyshev, op=sigmoid, validate=False, method=method), floats, stensor,
        sigmoid(floats), interval, skip_assert=True, periodic=False)
    
    _test_op(mpc, data_dump, f"chebyshev_exp_{method}",
        partial(via_chebyshev, op=exp, validate=False, method=method), floats, stensor,
        exp(floats), interval, skip_assert=True, periodic=False)
    
    _test_op(mpc, data_dump, f"chebyshev_sin_{method}",
        partial(via_chebyshev, op=sin, validate=False, method=method), floats, stensor,
        sin(floats), interval, skip_assert=True, periodic=False)
    
    _test_op(mpc, data_dump, f"chebyshev_cos_{method}",
        partial(via_chebyshev, op=cos, validate=False, method=method), floats, stensor,
        cos(floats), interval, skip_assert=True, periodic=False)
    
    _test_op(mpc, data_dump, f"chebyshev_tanh_{method}",
        partial(via_chebyshev, op=tanh, validate=False, method=method), floats, stensor,
        tanh(floats), interval, skip_assert=True, periodic=False)
    
    if interval[0] > 0:
        _test_op(mpc, data_dump, f"chebyshev_log_{method}",
            partial(via_chebyshev, op=log, validate=False, method=method), floats, stensor,
            log(floats), interval, skip_assert=True, periodic=False)
        
        _test_op(mpc, data_dump, f"chebyshev_mul_inv_{method}",
            partial(via_chebyshev, op=mul_inv, validate=False, method=method), floats, stensor,
            mul_inv(floats), interval, skip_assert=True, periodic=False)

        _test_op(mpc, data_dump, f"chebyshev_sqrt_{method}",
            partial(via_chebyshev, op=sqrt, validate=False, method=method), floats, stensor,
            sqrt(floats), interval, skip_assert=True, periodic=False)


def test_chebyshev(mpc, interval, size=100):
    modulus = mpc.default_mpc_modulus
    alg_struct = "ring" if modulus.popcnt() == 1 else "field"
    print(f'CP{mpc.pid}:\tTesting Sequre Chebyshev at interval {interval} on {alg_struct} ... \n')
    
    floats = linspace(*interval, size)
    stensor = Sharetensor.enc(mpc, array(floats), 0, modulus)
    data_dump = {'x': floats}
    
    _test_chebyshev_method(mpc, data_dump, floats, stensor, interval, method=POLY_EVAL_CLENSHAW)
    _test_chebyshev_method(mpc, data_dump, floats, stensor, interval, method=POLY_EVAL_DECOR)
    _test_chebyshev_method(mpc, data_dump, floats, stensor, interval, method=POLY_EVAL_NAIVE)

    return data_dump


def _test_decor_method(mpc, data_dump, floats, shared_floats, interval, *args, method: Static[str]):
    foo = get_decor_foo(*args, method=method)[0]
    if method == "polynomial":
        eval_foo = lambda x: ([args[1]].astype(float) @ foo(x))[0]
    else:
        eval_foo = foo

    with stats_log(mpc, f"decor_{method}", data_dump):
        shared_result = via_decor(mpc, shared_floats, interval, *args, method=method)
    
    ground_truth = eval_foo(floats)
    revealed_result = shared_result.reveal(mpc).tolist()
    if mpc.pid != 0:
        assert_eq_approx(
            f'Decor {method} for {floats}',
            revealed_result, ground_truth, error=0.1, silent_pass=True)

    data_dump[f'decor_{method}_result'] = revealed_result
    data_dump[f'decor_{method}_expected'] = ground_truth


def test_decor(mpc, interval, size=100):
    """
    Test Decor.
    """
    alg_struct = "ring" if mpc.default_mpc_modulus.popcnt() == 1 else "field"
    print(f'CP{mpc.pid}:\tTesting Decor internal methods at interval {interval} on {alg_struct} ... \n')
    
    floats = linspace(*interval, size)
    shared_floats = Sharetensor.enc(mpc, array(floats))
    data_dump = {'x': floats}

    _test_decor_method(
        mpc, data_dump, floats, shared_floats, interval, method="exp")
    _test_decor_method(
        mpc, data_dump, floats, shared_floats, interval, method="sigmoid")
    _test_decor_method(
        mpc, data_dump, floats, shared_floats, interval, method="tanh")
    _test_decor_method(
        mpc, data_dump, floats, shared_floats, interval, 3, list(range(1, 5)), method="polynomial")
    
    return data_dump


def eval_dti_model(
        mpc, X, y, X_test, y_test, act_1, act_2, loss,
        epochs=50, batch_size=50, learning_rate=0.2, momentum=0.9):
    input_dim = X.shape[1]
    
    if act_2 == "tanh" or loss == "hinge":
        y_final = secure_operator.sub(mpc, secure_operator.mul(mpc, y, 2), 1)
        y_test_final = y_test * 2 - 1
    
    layers = (
        Input[type(X)](input_dim),
        Dense[type(X)](act_1, 100, "normal", "zeros"),
        Dense[type(X)](act_2, 1, "normal", "zeros"))

    model = Sequential(layers).compile(mpc, loss=loss, optimizer="bgd")
    model.fit(
        mpc, X=X, y=y_final,
        batch_size=batch_size, step=learning_rate,
        epochs=epochs, momentum=momentum, verbose=True)

    preds = model.predict(mpc, X_test).reveal(mpc)
    if act_2 == "sigmoid":
        preds = (preds >= 0.5).astype(float)
    else:
        preds = preds.sign()
    
    return (preds == y_test_final).mean()


def test_dti(mpc):
    alg_struct = "ring" if mpc.default_mpc_modulus.popcnt() == 1 else "field"
    print(f'CP{mpc.pid}:\tTesting DTI on {alg_struct} ... \n')

    X = Sharetensor.enc(mpc, loadtxt("data/Xtrain", shape=(150, 6903)))
    y = Sharetensor.enc(mpc, loadtxt("data/ytrain", shape=(150, 1)))
    X_test = Sharetensor.enc(mpc, loadtxt("data/Xtest", shape=(48, 6903)))
    y_test = loadtxt("data/ytest", shape=(48, 1))

    number_of_runs = 1
    # TODO: Enable decor eval without interval to add support for sigmoid and tanh activations
    combinations = [
        ("relu", "linear", "hinge"),
        # ("relu", "tanh", "mean_squared_error"),
        # ("relu", "sigmoid", "binary_crossentropy")
    ]

    accuracies = defaultdict(float)
    for _ in range(number_of_runs):
        for comb in combinations:
            accuracies[comb] += eval_dti_model(mpc, X, y, X_test, y_test, *comb)

    print({k: (v / number_of_runs) for k,v in accuracies.items()})


@local
def test(mpc):
    intervals = [
        (-math.pi, math.pi),
        (-1.0, 2.5),
        (math.pi * 0.25, math.pi * 0.75),
        (-5.0, 5.0)
        ]

    for i, interval in enumerate(intervals):
        pickle_dump(mpc.pid, f"dump/decor_trig_{i}_{MPC_NBIT_F}.p", test_decor_trig(mpc, interval))
        pickle_dump(mpc.pid, f"dump/decor_exp_{i}_{MPC_NBIT_F}.p", test_decor_expm1(mpc, interval))
        pickle_dump(mpc.pid, f"dump/decor_{i}_{MPC_NBIT_F}.p", test_decor(mpc, interval))
        pickle_dump(mpc.pid, f"dump/fourier_{i}_{MPC_NBIT_F}.p", test_decor_fourier(mpc, interval))
        pickle_dump(mpc.pid, f"dump/cheby_{i}_{MPC_NBIT_F}.p", test_chebyshev(mpc, interval))
        pickle_dump(mpc.pid, f"dump/taylor_{i}_{MPC_NBIT_F}.p", test_taylor(mpc, interval))
    
    # TODO: Enable decor eval without interval to add support for sigmoid and tanh activations
    # print("DTI accuracies: ", test_dti(mpc))


test()
