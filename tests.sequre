        # stensor_exp_x_r_p = Sharetensor(exp_x_r_p, True, True, modulus)
        # stensor_exp_r = Sharetensor(shared_exp_r, True, modulus)
        # stensor_r_frac = Sharetensor(shared_r_frac, True, modulus)
        
        # shared_result = beaver_exp(mpc, stensor_exp_x_r, stensor_exp_x_r_p, stensor_exp_r, stensor_r_frac, stensor_floats)
        # e = time.time()
        # sequre_total_time += e - s
        
        # if mpc.pid != 0:
        #     assert_eq_approx(
        #         f'Beaver exp via Sequre (iteration {i}/{iterations}) for {floats}',
        #         shared_result.reveal(mpc).tolist(), expc(floats), silent_pass=True)

        data_dump = {
            'x': floats,
            'beaver_expc': revealed_result,
            'beaver_expc_expected': expc(floats)}

    avg_time = plain_total_time / iterations
    print(f'CP{mpc.pid}:\tGeneralized Exp Beaver tests passed.\n\tRuntime per iteration (plain): {avg_time} seconds\n\tRuntime per iteration (Sequre): {sequre_total_time / iterations} seconds')
    data_dump['beaver_expc_time'] = [avg_time]
    return data_dump


def test_op(mpc, data_dump, msg, op, raw_input, mpc_input, expected_result, interval, error=0.01, skip_assert=False, periodic=True):
    alg_struct = "ring" if mpc.default_mpc_modulus.popcnt() == 1 else "field"
    period = interval[1] - interval[0]
    
    s = time.time()
    mpc_result = op(mpc, mpc_input, interval)
    e = time.time()
    data_dump[f"{msg}_time"] = [e - s]
    revealed_result = mpc_result.reveal(mpc).tolist()
    
    revealed_input = mpc_input.reveal(mpc).tolist()
    if not skip_assert:
        assert_distributed_eq_approx(mpc, f'CP{mpc.pid}:\tSequre {msg} at interval {interval} (MPC) on {alg_struct}', revealed_result, expected_result, error)
        assert_distributed_eq_approx(mpc, f'CP{mpc.pid}:\tMPC input intact post {msg} on {alg_struct}', (revealed_input * period) if periodic else revealed_input, raw_input, error, silent_pass=True)

    data_dump[msg] = revealed_result
    data_dump[f"{msg}_expected"] = expected_result


def test_beaver_fourier(mpc, interval, size=100):
    period = interval[1] - interval[0]
    modulus = mpc.default_mpc_modulus
    alg_struct = "ring" if modulus.popcnt() == 1 else "field"
    print(f'CP{mpc.pid}:\tTesting Sequre Beaver Fourier at interval {interval} on {alg_struct} ... \n')
    
    floats = linspace(*interval, size)
    fp_floats = period_double_to_fp(floats, period, modulus)
    shared_fp = mpc.comms.share_from_trusted_dealer(fp_floats, modulus)
    stensor = Sharetensor(shared_fp, modulus)
    stensor.fp = True
    data_dump = {'x': floats}
    
    test_op(mpc, data_dump, "fourier_sin",
        fourier_sin, floats, stensor, sin(floats), interval, skip_assert=True)
    
    test_op(mpc, data_dump, "fourier_cos",
        fourier_cos, floats, stensor, cos(floats), interval, skip_assert=True)
    
    test_op(mpc, data_dump, "fourier_sigmoid",
        fourier_sigmoid, floats, stensor, sigmoid(floats), interval, skip_assert=True)
    
    test_op(mpc, data_dump, "fourier_exp",
        fourier_exp, floats, stensor, exp(floats), interval, skip_assert=True)
    
    if interval[0] > 0:
        test_op(mpc, data_dump, "fourier_log",
            fourier_log, floats, stensor, log(floats), interval, skip_assert=True)
        
        test_op(mpc, data_dump, "fourier_mul_inv",
            fourier_mul_inv, floats, stensor, mul_inv(floats), interval, skip_assert=True)

        test_op(mpc, data_dump, "fourier_sqrt",
            fourier_sqrt, floats, stensor, sqrt(floats), interval, skip_assert=True)

    return data_dump


def test_beaver_taylor(mpc, interval, size=100):
    period = interval[1] - interval[0]
    modulus = mpc.default_mpc_modulus
    alg_struct = "ring" if modulus.popcnt() == 1 else "field"
    print(f'CP{mpc.pid}:\tTesting Sequre Beaver Taylor at interval {interval} on {alg_struct} ... \n')
    
    floats = linspace(*interval, size)
    fp_floats = period_double_to_fp(floats, period, modulus)
    shared_fp = mpc.comms.share_from_trusted_dealer(fp_floats, modulus)
    stensor = Sharetensor(shared_fp, modulus)
    stensor.fp = True
    data_dump = {'x': floats}

    test_op(mpc, data_dump, "taylor_sin",
            taylor_sin, floats, stensor, sin(floats), interval)
    
    test_op(mpc, data_dump, "taylor_cos",
            taylor_cos, floats, stensor, cos(floats), interval)
    
    test_op(mpc, data_dump, "taylor_sigmoid",
            taylor_sigmoid, floats, stensor, sigmoid(floats), interval)
    
    return data_dump


def test_chebyshev(mpc, interval, size=100):
    modulus = mpc.default_mpc_modulus
    alg_struct = "ring" if modulus.popcnt() == 1 else "field"
    print(f'CP{mpc.pid}:\tTesting Sequre Chebyshev at interval {interval} on {alg_struct} ... \n')
    
    floats = linspace(*interval, size)
    stensor = Sharetensor.enc(mpc, array(floats), 0, modulus)
    data_dump = {'x': floats}
    
    test_op(mpc, data_dump, "chebyshev_sigmoid",
        chebyshev_sigmoid, floats, stensor, sigmoid(floats), interval, periodic=False)
    
    test_op(mpc, data_dump, "chebyshev_exp",
        chebyshev_exp, floats, stensor, exp(floats), interval, periodic=False)
    
    test_op(mpc, data_dump, "chebyshev_sin",
        chebyshev_sin, floats, stensor, sin(floats), interval, periodic=False)
    
    test_op(mpc, data_dump, "chebyshev_cos",
        chebyshev_cos, floats, stensor, cos(floats), interval, periodic=False)
    
    if interval[0] > 0:
        test_op(mpc, data_dump, "chebyshev_log",
            chebyshev_log, floats, stensor, log(floats), interval, periodic=False)
        
        test_op(mpc, data_dump, "chebyshev_mul_inv",
            chebyshev_mul_inv, floats, stensor, mul_inv(floats), interval, periodic=False)

        test_op(mpc, data_dump, "chebyshev_sqrt",
            chebyshev_sqrt, floats, stensor, sqrt(floats), interval, periodic=False)

    return data_dump


@local
def test(mpc):
    pickle_dump("_dump_beaver_trig.p", test_beaver_trig(mpc))
    pickle_dump("_dump_beaver_exp.p", test_beaver_exp(mpc))
    
    pickle_dump("_dump_fourier_full_circle.p", test_beaver_fourier(mpc, (-math.pi, math.pi)))
    pickle_dump("_dump_fourier_partial_circle.p", test_beaver_fourier(mpc, (-1.0, 2.5)))
    pickle_dump("_dump_fourier_positive_quad.p", test_beaver_fourier(mpc, (math.pi * 0.25, math.pi * 0.75)))

    pickle_dump("_dump_cheby_full_circle.p", test_chebyshev(mpc, (-math.pi, math.pi)))
    pickle_dump("_dump_cheby_partial_circle.p", test_chebyshev(mpc, (-1.0, 2.5)))
    pickle_dump("_dump_cheby_positive_quad.p", test_chebyshev(mpc, (math.pi * 0.25, math.pi * 0.75)))
    

test()
