def test_op(mpc, msg, op, raw_mat, mpc_mat, expected_result, interval, error=0.01):
    alg_struct = "ring" if mpc.default_mpc_modulus.popcnt() == 1 else "field"
    period = interval[1] - interval[0]
    mpc_result = op(mpc, mpc_mat, interval)
    assert_distributed_eq_approx(mpc, f'CP{mpc.pid}:\tSequre {msg} (MPC) on {alg_struct}', mpc_result.reveal(mpc).tolist(), expected_result, error)
    assert_distributed_eq_approx(mpc, f'CP{mpc.pid}:\tMPC input intact post {msg} on {alg_struct}', mpc_mat.reveal(mpc).tolist() * period, raw_mat, error, silent_pass=True)


def test_beaver_fourier(mpc, interval, shape=(3,)):
    period = interval[1] - interval[0]
    modulus = mpc.default_mpc_modulus
    alg_struct = "ring" if modulus.popcnt() == 1 else "field"
    print(f'CP{mpc.pid}:\tTesting Sequre Beaver Fourier at interval {interval} on {alg_struct} ... \n')
    
    with mpc.randomness.seed_switch(-1):
        floats = random_floats(shape, period) + interval[0]
    
    fp_floats = period_double_to_fp(floats, period, modulus)
    shared_fp = mpc.comms.share_from_trusted_dealer(fp_floats, modulus)
    stensor = Sharetensor(shared_fp, modulus)
    stensor.fp = True

    test_op(mpc, f"Fourier sin at interval {interval}",
            fourier_sin, floats, stensor, sin(floats), interval, 0.3)
    
    test_op(mpc, f"Fourier cos at interval {interval}",
            fourier_cos, floats, stensor, cos(floats), interval, 0.3)
    
    test_op(mpc, f"Fourier sigmoid at interval {interval}",
            fourier_sigmoid, floats, stensor, sigmoid(floats), interval, 0.3)


def test_beaver_taylor(mpc, interval, shape=(3,)):
    period = interval[1] - interval[0]
    modulus = mpc.default_mpc_modulus
    alg_struct = "ring" if modulus.popcnt() == 1 else "field"
    print(f'CP{mpc.pid}:\tTesting Sequre Beaver Taylor at interval {interval} on {alg_struct} ... \n')
    
    with mpc.randomness.seed_switch(-1):
        floats = random_floats(shape, 1)
    
    fp_floats = period_double_to_fp(floats, period, modulus)
    shared_fp = mpc.comms.share_from_trusted_dealer(fp_floats, modulus)
    stensor = Sharetensor(shared_fp, modulus)
    stensor.fp = True

    test_op(mpc, f"Taylor sin at interval {interval}",
            taylor_sin, floats, stensor, sin(floats), interval)
    
    test_op(mpc, f"Taylor cos at interval {interval}",
            taylor_cos, floats, stensor, cos(floats), interval)
    
    test_op(mpc, f"Taylor sigmoid at interval {interval}",
            taylor_sigmoid, floats, stensor, sigmoid(floats), interval)


@local
def test(mpc):
    test_beaver_trig(mpc)
    test_beaver_exp(mpc)
    
    test_beaver_fourier(mpc, (-math.pi, math.pi))
    test_beaver_fourier(mpc, (-math.pi, math.pi / 2))

test()
