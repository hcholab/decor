import secure_operator
import openmp as omp

from functools import partial

from sequre import sequre
from sequre.types.sharetensor import Sharetensor
from sequre.types.internal import InternalMPC
from sequre.types.utils import double_to_fp
from sequre.mpc.env import MPCEnv
from sequre.mpc.fp import MPCFP
from sequre.mpc.comms import MPCComms

from patch.boolean import MPCBoolean
from patch.constants import (
    FBITS_MASK, NETWORK_DELAY_TIME, MPC_NBIT_F,
    MPC_NBIT_K, NUM_THREADS, mpc_uint)
